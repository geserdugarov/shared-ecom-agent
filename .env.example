# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (same directory) and fill in your own values.
# `.env` is git-ignored and must NEVER be committed.
#
#   cp .env.example .env
#
# main.py loads `.env` from the project root at startup. Hermes inherits this
# process environment, so OPENROUTER_API_KEY reaches the model provider with
# no extra wiring.
# ─────────────────────────────────────────────────────────────────────────

# --- Required ---------------------------------------------------------------

# OpenRouter API key used by Hermes for inference (https://openrouter.ai/keys).
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# BitGN benchmark API key (used to submit a run for scoring).
BITGN_API_KEY=your-bitgn-api-key-here

# Which benchmark to run. Examples: bitgn/ecom1-dev, bitgn/ecom1-prod
BENCH_ID=bitgn/ecom1-dev

# --- Optional: model selection ---------------------------------------------

# Default model for the bulk of tasks (cheap, fast).
MODEL_ID=deepseek/deepseek-v4-flash

# Model used only for the count/resolve/availability/fraud task cluster that
# the default model struggles with (see main.py:_route_model).
PRO_MODEL_ID=deepseek/deepseek-v4-pro

# --- Optional: run tuning ---------------------------------------------------

# Number of parallel trial workers (1 = sequential).
WORKERS=4

# Label shown for your run in the BitGN dashboard.
RUN_NAME=bitgn-ecom-agent

# Per-task wall-clock limit for a single hermes invocation, in seconds.
HERMES_TIMEOUT_SEC=900

# --- Optional: advanced overrides (rarely needed) ---------------------------

# Explicit path to the hermes binary (otherwise resolved from the venv / PATH).
# HERMES_BIN=/path/to/venv/bin/hermes

# Override the interpreter / file used to launch the MCP server.
# ECOM_MCP_PYTHON=/path/to/venv/bin/python
# ECOM_MCP_SERVER=/path/to/agent/ecom_mcp_server.py

# Point at a non-default .env file.
# ECOM_ENV_FILE=/path/to/.env

# BitGN harness host (defaults to https://api.bitgn.com).
# BITGN_HOST=https://api.bitgn.com
